PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/taskflowx?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_taskflowx2024
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too_taskflowx2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

# Google OAuth (optional - scaffolded but disabled by default)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# AI (optional - mock AI used by default)
OPENAI_API_KEY=your_openai_api_key_here
USE_MOCK_AI=true
